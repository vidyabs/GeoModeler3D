<Window x:Class="GeoModeler3D.App.Views.Dialogs.CreateConeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Cone" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock Text="Base Center" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,2">
            <TextBlock Text="X" Width="20" VerticalAlignment="Center"/>
            <TextBox x:Name="CenterX" Width="80" Text="0" Margin="0,0,8,0"/>
            <TextBlock Text="Y" Width="20" VerticalAlignment="Center"/>
            <TextBox x:Name="CenterY" Width="80" Text="0" Margin="0,0,8,0"/>
            <TextBlock Text="Z" Width="20" VerticalAlignment="Center"/>
            <TextBox x:Name="CenterZ" Width="80" Text="0"/>
        </StackPanel>

        <TextBlock Text="Axis" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,2">
            <TextBlock Text="X" Width="20" VerticalAlignment="Center"/>
            <TextBox x:Name="AxisX" Width="80" Text="0" Margin="0,0,8,0"/>
            <TextBlock Text="Y" Width="20" VerticalAlignment="Center"/>
            <TextBox x:Name="AxisY" Width="80" Text="0" Margin="0,0,8,0"/>
            <TextBlock Text="Z" Width="20" VerticalAlignment="Center"/>
            <TextBox x:Name="AxisZ" Width="80" Text="1"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <StackPanel Margin="0,0,16,0">
                <TextBlock Text="Base Radius" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="RadiusBox" Width="80" HorizontalAlignment="Left" Text="1"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Height" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="HeightBox" Width="80" HorizontalAlignment="Left" Text="2"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="75" Height="28" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="Cancel" Width="75" Height="28" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
