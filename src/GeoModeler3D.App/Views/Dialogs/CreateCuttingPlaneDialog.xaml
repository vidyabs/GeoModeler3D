<Window x:Class="GeoModeler3D.App.Views.Dialogs.CreateCuttingPlaneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Cutting Plane" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Width="360">
    <StackPanel Margin="16">

        <TextBlock Text="Origin" FontWeight="SemiBold" Foreground="#FF2B579A" Margin="0,0,0,4"/>
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="X" VerticalAlignment="Center" Foreground="#FF555555"/>
            <TextBox x:Name="OriginX" Grid.Column="1" Text="0"/>
        </Grid>
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Y" VerticalAlignment="Center" Foreground="#FF555555"/>
            <TextBox x:Name="OriginY" Grid.Column="1" Text="0"/>
        </Grid>
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Z" VerticalAlignment="Center" Foreground="#FF555555"/>
            <TextBox x:Name="OriginZ" Grid.Column="1" Text="0"/>
        </Grid>

        <TextBlock Text="Normal" FontWeight="SemiBold" Foreground="#FF2B579A" Margin="0,10,0,4"/>
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="I" VerticalAlignment="Center" Foreground="#FF555555"/>
            <TextBox x:Name="NormI" Grid.Column="1" Text="0"/>
        </Grid>
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="J" VerticalAlignment="Center" Foreground="#FF555555"/>
            <TextBox x:Name="NormJ" Grid.Column="1" Text="0"/>
        </Grid>
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="K" VerticalAlignment="Center" Foreground="#FF555555"/>
            <TextBox x:Name="NormK" Grid.Column="1" Text="1"/>
        </Grid>

        <TextBlock Text="Display" FontWeight="SemiBold" Foreground="#FF2B579A" Margin="0,10,0,4"/>
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Width" VerticalAlignment="Center" Foreground="#FF555555"/>
            <TextBox x:Name="DisplayWidth" Grid.Column="1" Text="10"/>
        </Grid>
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Height" VerticalAlignment="Center" Foreground="#FF555555"/>
            <TextBox x:Name="DisplayHeight" Grid.Column="1" Text="10"/>
        </Grid>
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
            <TextBlock Text="Opacity" VerticalAlignment="Center" Foreground="#FF555555"/>
            <Slider x:Name="OpacitySlider" Grid.Column="1" Minimum="0" Maximum="1" Value="0.3"
                    VerticalAlignment="Center" ValueChanged="OnOpacityChanged"/>
            <TextBlock x:Name="OpacityLabel" Grid.Column="2" Text="0.30" VerticalAlignment="Center"
                       Margin="4,0,0,0" Foreground="#FF333333" FontSize="11"/>
        </Grid>

        <TextBlock Text="Clipping" FontWeight="SemiBold" Foreground="#FF2B579A" Margin="0,10,0,4"/>
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Clip Side" VerticalAlignment="Center" Foreground="#FF555555"/>
            <ComboBox x:Name="ClipSideCombo" Grid.Column="1"
                      SelectionChanged="OnClipSideChanged">
                <ComboBoxItem Content="None" Tag="None" IsSelected="True"/>
                <ComboBoxItem Content="Positive (show +N side)" Tag="Positive"/>
                <ComboBoxItem Content="Negative (show −N side)" Tag="Negative"/>
                <ComboBoxItem Content="Both with gap" Tag="BothWithGap"/>
            </ComboBox>
        </Grid>
        <Grid x:Name="GapRow" Margin="0,2" Visibility="Collapsed">
            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Gap" VerticalAlignment="Center" Foreground="#FF555555"/>
            <TextBox x:Name="GapDistanceBox" Grid.Column="1" Text="0.5"/>
        </Grid>

        <CheckBox x:Name="CappingCheck" Content="Enable capping" Margin="0,8,0,0"/>

        <TextBlock Text="Target Entities (optional)" FontWeight="SemiBold" Foreground="#FF2B579A" Margin="0,10,0,4"/>
        <TextBlock Text="Ctrl+click to select entities for visual clipping:"
                   Foreground="#FF555555" FontSize="11" Margin="0,0,0,4"/>
        <ListBox x:Name="TargetList" Height="100" SelectionMode="Extended"
                 BorderThickness="1" BorderBrush="#FFBBBBBB"/>

        <Separator Margin="0,12,0,12"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Create" Width="75" Height="28" Margin="0,0,8,0"
                    IsDefault="True" Click="OnCreate"/>
            <Button Content="Cancel" Width="75" Height="28" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
