<Window x:Class="GeoModeler3D.App.Views.Dialogs.CreatePointDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Point" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock Text="Position" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,2">
            <TextBlock Text="X" Width="20" VerticalAlignment="Center"/>
            <TextBox x:Name="PosX" Width="80" Text="0" Margin="0,0,8,0"/>
            <TextBlock Text="Y" Width="20" VerticalAlignment="Center"/>
            <TextBox x:Name="PosY" Width="80" Text="0" Margin="0,0,8,0"/>
            <TextBlock Text="Z" Width="20" VerticalAlignment="Center"/>
            <TextBox x:Name="PosZ" Width="80" Text="0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="75" Height="28" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="Cancel" Width="75" Height="28" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
