<Window x:Class="GeoModeler3D.App.Views.Dialogs.CreatePlaneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Plane" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Width="340">
    <StackPanel Margin="16">

        <!-- Mode selector -->
        <RadioButton x:Name="ModeEntities" Content="From selected point and vector entities"
                     IsChecked="True" Checked="OnModeChanged" FontWeight="SemiBold"/>
        <RadioButton x:Name="ModeManual" Content="Enter origin and normal manually"
                     Checked="OnModeChanged" Margin="0,6,0,12"/>

        <!-- Entity mode panel -->
        <StackPanel x:Name="EntityPanel">
            <TextBlock Text="Origin point:" Foreground="#FF555555" FontSize="11"/>
            <TextBlock x:Name="PointInfo" FontFamily="Consolas" Margin="0,2,0,10"
                       Foreground="#FF333333"/>
            <TextBlock Text="Normal vector:" Foreground="#FF555555" FontSize="11"/>
            <TextBlock x:Name="VectorInfo" FontFamily="Consolas" Margin="0,2,0,0"
                       Foreground="#FF333333"/>
        </StackPanel>

        <!-- Manual input panel -->
        <StackPanel x:Name="ManualPanel" Visibility="Collapsed">
            <TextBlock Text="Origin" FontWeight="SemiBold" Foreground="#FF2B579A" Margin="0,0,0,4"/>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="X" VerticalAlignment="Center" Foreground="#FF555555"/>
                <TextBox x:Name="OriginX" Grid.Column="1" Text="0"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Y" VerticalAlignment="Center" Foreground="#FF555555"/>
                <TextBox x:Name="OriginY" Grid.Column="1" Text="0"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Z" VerticalAlignment="Center" Foreground="#FF555555"/>
                <TextBox x:Name="OriginZ" Grid.Column="1" Text="0"/>
            </Grid>

            <TextBlock Text="Normal" FontWeight="SemiBold" Foreground="#FF2B579A" Margin="0,10,0,4"/>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="I" VerticalAlignment="Center" Foreground="#FF555555"/>
                <TextBox x:Name="NormI" Grid.Column="1" Text="0"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="J" VerticalAlignment="Center" Foreground="#FF555555"/>
                <TextBox x:Name="NormJ" Grid.Column="1" Text="0"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="K" VerticalAlignment="Center" Foreground="#FF555555"/>
                <TextBox x:Name="NormK" Grid.Column="1" Text="1"/>
            </Grid>
        </StackPanel>

        <Separator Margin="0,12,0,12"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Create" Width="75" Height="28" Margin="0,0,8,0"
                    IsDefault="True" Click="OnCreate"/>
            <Button Content="Cancel" Width="75" Height="28" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
