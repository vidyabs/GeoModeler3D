<UserControl x:Class="GeoModeler3D.App.Views.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GeoModeler3D.App.Converters"
             xmlns:entities="clr-namespace:GeoModeler3D.Core.Entities;assembly=GeoModeler3D.Core">
    <UserControl.Resources>
        <conv:ColorToBrushConverter x:Key="ColorToBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:Vector3ComponentConverter x:Key="Vec3Comp"/>

        <Style x:Key="PropLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF555555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="PropValue" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF2B579A"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <!-- Point -->
        <DataTemplate DataType="{x:Type entities:PointEntity}">
            <StackPanel>
                <TextBlock Text="Geometry" Style="{StaticResource SectionHeader}"/>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="X" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Position, Converter={StaticResource Vec3Comp}, ConverterParameter=X}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Y" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Position, Converter={StaticResource Vec3Comp}, ConverterParameter=Y}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Z" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Position, Converter={StaticResource Vec3Comp}, ConverterParameter=Z}" Style="{StaticResource PropValue}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Sphere -->
        <DataTemplate DataType="{x:Type entities:SphereEntity}">
            <StackPanel>
                <TextBlock Text="Geometry" Style="{StaticResource SectionHeader}"/>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Center X" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Center, Converter={StaticResource Vec3Comp}, ConverterParameter=X}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Center Y" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Center, Converter={StaticResource Vec3Comp}, ConverterParameter=Y}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Center Z" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Center, Converter={StaticResource Vec3Comp}, ConverterParameter=Z}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Radius" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Radius, StringFormat=F3}" Style="{StaticResource PropValue}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Cylinder -->
        <DataTemplate DataType="{x:Type entities:CylinderEntity}">
            <StackPanel>
                <TextBlock Text="Geometry" Style="{StaticResource SectionHeader}"/>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Base X" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding BaseCenter, Converter={StaticResource Vec3Comp}, ConverterParameter=X}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Base Y" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding BaseCenter, Converter={StaticResource Vec3Comp}, ConverterParameter=Y}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Base Z" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding BaseCenter, Converter={StaticResource Vec3Comp}, ConverterParameter=Z}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Axis X" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Axis, Converter={StaticResource Vec3Comp}, ConverterParameter=X}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Axis Y" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Axis, Converter={StaticResource Vec3Comp}, ConverterParameter=Y}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Axis Z" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Axis, Converter={StaticResource Vec3Comp}, ConverterParameter=Z}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Radius" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Radius, StringFormat=F3}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Height" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Height, StringFormat=F3}" Style="{StaticResource PropValue}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Cone -->
        <DataTemplate DataType="{x:Type entities:ConeEntity}">
            <StackPanel>
                <TextBlock Text="Geometry" Style="{StaticResource SectionHeader}"/>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Base X" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding BaseCenter, Converter={StaticResource Vec3Comp}, ConverterParameter=X}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Base Y" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding BaseCenter, Converter={StaticResource Vec3Comp}, ConverterParameter=Y}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Base Z" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding BaseCenter, Converter={StaticResource Vec3Comp}, ConverterParameter=Z}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Axis X" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Axis, Converter={StaticResource Vec3Comp}, ConverterParameter=X}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Axis Y" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Axis, Converter={StaticResource Vec3Comp}, ConverterParameter=Y}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Axis Z" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Axis, Converter={StaticResource Vec3Comp}, ConverterParameter=Z}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Base Radius" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding BaseRadius, StringFormat=F3}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Height" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Height, StringFormat=F3}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Half Angle" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding HalfAngle, StringFormat=F3}" Style="{StaticResource PropValue}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Torus -->
        <DataTemplate DataType="{x:Type entities:TorusEntity}">
            <StackPanel>
                <TextBlock Text="Geometry" Style="{StaticResource SectionHeader}"/>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Center X" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Center, Converter={StaticResource Vec3Comp}, ConverterParameter=X}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Center Y" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Center, Converter={StaticResource Vec3Comp}, ConverterParameter=Y}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Center Z" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Center, Converter={StaticResource Vec3Comp}, ConverterParameter=Z}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Normal X" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Normal, Converter={StaticResource Vec3Comp}, ConverterParameter=X}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Normal Y" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Normal, Converter={StaticResource Vec3Comp}, ConverterParameter=Y}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Normal Z" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Normal, Converter={StaticResource Vec3Comp}, ConverterParameter=Z}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Major R" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding MajorRadius, StringFormat=F3}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Minor R" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding MinorRadius, StringFormat=F3}" Style="{StaticResource PropValue}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
        <StackPanel Margin="8">
            <TextBlock Text="Properties" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

            <TextBlock Text="No entity selected"
                       Visibility="{Binding SelectedEntity, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                       Foreground="Gray" FontStyle="Italic"/>

            <StackPanel Visibility="{Binding SelectedEntity, Converter={StaticResource BoolToVis}}">

                <TextBlock Text="{Binding EntityTypeName}" FontWeight="SemiBold" FontSize="13"
                           Foreground="#FF2B579A" Margin="0,0,0,6"/>

                <!-- Common properties -->
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Name" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntity.Name}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Visible" Style="{StaticResource PropLabel}"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding SelectedEntity.IsVisible}" VerticalAlignment="Center"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Color" Style="{StaticResource PropLabel}"/>
                    <Rectangle Grid.Column="1" Width="24" Height="16" HorizontalAlignment="Left"
                               Fill="{Binding SelectedEntity.Color, Converter={StaticResource ColorToBrush}}"
                               Stroke="Gray" StrokeThickness="1"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Layer" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntity.Layer}" Style="{StaticResource PropValue}"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="ID" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntity.Id}" FontSize="9"
                               Foreground="Gray" VerticalAlignment="Center"/>
                </Grid>

                <!-- Entity-specific properties via DataTemplate -->
                <ContentControl Content="{Binding SelectedEntity}" Margin="0,4,0,0"/>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
