                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="V2 Z" Style="{StaticResource PropLabel}"/>
                    <TextBox Grid.Column="1" Tag="Vertex2.Z"
                             Text="{Binding Vertex2, Converter={StaticResource Vec3Comp}, ConverterParameter=Z, Mode=OneWay}"
                             Style="{StaticResource EditBox}" LostFocus="OnEditLostFocus" KeyDown="OnEditKeyDown"/>
                </Grid>
                <TextBlock Text="Computed" Style="{StaticResource SectionHeader}"/>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Normal" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Style="{StaticResource PropValue}">
                        <Run Text="{Binding Normal, Converter={StaticResource Vec3Comp}, ConverterParameter=X, Mode=OneWay}"/>
                        <Run Text=", "/>
                        <Run Text="{Binding Normal, Converter={StaticResource Vec3Comp}, ConverterParameter=Y, Mode=OneWay}"/>
                        <Run Text=", "/>
                        <Run Text="{Binding Normal, Converter={StaticResource Vec3Comp}, ConverterParameter=Z, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Area" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Area, StringFormat=F4}" Style="{StaticResource PropValue}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

