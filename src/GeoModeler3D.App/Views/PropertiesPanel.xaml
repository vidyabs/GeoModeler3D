<UserControl x:Class="GeoModeler3D.App.Views.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GeoModeler3D.App.Converters"
             xmlns:entities="clr-namespace:GeoModeler3D.Core.Entities;assembly=GeoModeler3D.Core">
    <UserControl.Resources>
        <conv:ColorToBrushConverter x:Key="ColorToBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:Vector3ComponentConverter x:Key="Vec3Comp"/>

        <Style x:Key="PropLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF555555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="PropValue" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF2B579A"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="EditBox" TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#FFBBBBBB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="1,0"/>
            <Setter Property="Height" Value="20"/>
        </Style>

        <!-- Point -->
        <DataTemplate DataType="{x:Type entities:PointEntity}">
            <StackPanel>
                <TextBlock Text="Geometry" Style="{StaticResource SectionHeader}"/>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="X" Style="{StaticResource PropLabel}"/>
                    <TextBox Grid.Column="1" Tag="Position.X"
                             Text="{Binding Position, Converter={StaticResource Vec3Comp}, ConverterParameter=X, Mode=OneWay}"
                             Style="{StaticResource EditBox}"
                             LostFocus="OnEditLostFocus" KeyDown="OnEditKeyDown"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Y" Style="{StaticResource PropLabel}"/>
                    <TextBox Grid.Column="1" Tag="Position.Y"
                             Text="{Binding Position, Converter={StaticResource Vec3Comp}, ConverterParameter=Y, Mode=OneWay}"
                             Style="{StaticResource EditBox}"
                             LostFocus="OnEditLostFocus" KeyDown="OnEditKeyDown"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Z" Style="{StaticResource PropLabel}"/>
                    <TextBox Grid.Column="1" Tag="Position.Z"
                             Text="{Binding Position, Converter={StaticResource Vec3Comp}, ConverterParameter=Z, Mode=OneWay}"
                             Style="{StaticResource EditBox}"
                             LostFocus="OnEditLostFocus" KeyDown="OnEditKeyDown"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

