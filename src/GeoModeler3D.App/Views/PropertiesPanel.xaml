<UserControl x:Class="GeoModeler3D.App.Views.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GeoModeler3D.App.Converters">
    <UserControl.Resources>
        <conv:ColorToBrushConverter x:Key="ColorToBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
        <StackPanel>
            <TextBlock Text="Properties" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

            <TextBlock Text="No entity selected"
                       Visibility="{Binding SelectedEntity, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                       Foreground="Gray" FontStyle="Italic"/>

            <StackPanel Visibility="{Binding SelectedEntity, Converter={StaticResource BoolToVis}}"
                        DataContext="{Binding}">

                <TextBlock Text="{Binding EntityTypeName}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Name" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntity.Name}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ID" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntity.Id}" FontSize="10"
                               Foreground="Gray" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Visible" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding SelectedEntity.IsVisible}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Color" VerticalAlignment="Center"/>
                    <Rectangle Grid.Column="1" Width="24" Height="16" HorizontalAlignment="Left"
                               Fill="{Binding SelectedEntity.Color, Converter={StaticResource ColorToBrush}}"
                               Stroke="Gray" StrokeThickness="1"/>
                </Grid>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Layer" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntity.Layer}" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
