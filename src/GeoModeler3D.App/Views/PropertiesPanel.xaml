                </Grid>
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
        <StackPanel Margin="8">
            <TextBlock Text="Properties" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

            <TextBlock Text="No entity selected"
                       Visibility="{Binding SelectedEntity, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                       Foreground="Gray" FontStyle="Italic"/>

            <StackPanel Visibility="{Binding SelectedEntity, Converter={StaticResource BoolToVis}}">

                <TextBlock Text="{Binding EntityTypeName}" FontWeight="SemiBold" FontSize="13"
                           Foreground="#FF2B579A" Margin="0,0,0,6"/>

                <!-- Common properties -->
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Name" Style="{StaticResource PropLabel}"/>
                    <TextBox Grid.Column="1" Tag="Name"
                             Text="{Binding SelectedEntity.Name, Mode=OneWay}"
                             Style="{StaticResource EditBox}"
                             LostFocus="OnEditLostFocus" KeyDown="OnEditKeyDown"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Visible" Style="{StaticResource PropLabel}"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding SelectedEntity.IsVisible}" VerticalAlignment="Center"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Color" Style="{StaticResource PropLabel}"/>
                    <Rectangle Grid.Column="1" Width="24" Height="16" HorizontalAlignment="Left"
                               Fill="{Binding SelectedEntity.Color, Converter={StaticResource ColorToBrush}}"
                               Stroke="Gray" StrokeThickness="1"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Layer" Style="{StaticResource PropLabel}"/>
                    <TextBox Grid.Column="1" Tag="Layer"
                             Text="{Binding SelectedEntity.Layer, Mode=OneWay}"
                             Style="{StaticResource EditBox}"
                             LostFocus="OnEditLostFocus" KeyDown="OnEditKeyDown"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="ID" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntity.Id}" FontSize="9"
                               Foreground="Gray" VerticalAlignment="Center"/>
                </Grid>

                <!-- Entity-specific properties via DataTemplate -->
                <ContentControl Content="{Binding SelectedEntity}" Margin="0,4,0,0"/>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
