                             Text="{Binding Center, Converter={StaticResource Vec3Comp}, ConverterParameter=X, Mode=OneWay}"
                             Style="{StaticResource EditBox}"
                             LostFocus="OnEditLostFocus" KeyDown="OnEditKeyDown"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Center Y" Style="{StaticResource PropLabel}"/>
                    <TextBox Grid.Column="1" Tag="Center.Y"
                             Text="{Binding Center, Converter={StaticResource Vec3Comp}, ConverterParameter=Y, Mode=OneWay}"
                             Style="{StaticResource EditBox}"
                             LostFocus="OnEditLostFocus" KeyDown="OnEditKeyDown"/>
                </Grid>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Center Z" Style="{StaticResource PropLabel}"/>
