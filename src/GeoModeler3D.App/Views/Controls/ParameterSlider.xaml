<UserControl x:Class="GeoModeler3D.App.Views.Controls.ParameterSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="30">
    <StackPanel Orientation="Horizontal">
        <TextBlock x:Name="LabelText" Width="60" VerticalAlignment="Center" Text="Param"/>
        <Slider x:Name="ValueSlider" Width="120" Minimum="0" Maximum="100" Value="50"
                VerticalAlignment="Center"/>
        <TextBlock Text="{Binding Value, ElementName=ValueSlider, StringFormat=F2}"
                   Width="50" VerticalAlignment="Center" Margin="4,0"/>
    </StackPanel>
</UserControl>
