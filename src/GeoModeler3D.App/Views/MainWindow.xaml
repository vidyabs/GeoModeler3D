<Window x:Class="GeoModeler3D.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GeoModeler3D.App.Views"
        xmlns:conv="clr-namespace:GeoModeler3D.App.Converters"
        Title="{Binding Title}" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <conv:ColorToBrushConverter x:Key="ColorToBrush"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewSceneCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenSceneCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveSceneCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveSceneAsCommand}"/>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}"/>
        <KeyBinding Gesture="Ctrl+I" Command="{Binding ImportMeshCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewSceneCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open..." Command="{Binding OpenSceneCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="Import _Mesh..." Command="{Binding ImportMeshCommand}" InputGestureText="Ctrl+I"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveSceneCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveSceneAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Delete" Command="{Binding DeleteSelectedCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="_Create">
                <MenuItem Header="_Sphere..." Click="OnCreateSphere"/>
                <MenuItem Header="C_ylinder..." Click="OnCreateCylinder"/>
                <MenuItem Header="C_one..." Click="OnCreateCone"/>
                <MenuItem Header="_Torus..." Click="OnCreateTorus"/>
                <MenuItem Header="_Point..." Click="OnCreatePoint"/>
                <Separator/>
                <MenuItem Header="_Triangle from 3 Points..." Click="OnCreateTriangle"/>
                <Separator/>
                <MenuItem Header="Create _Vector..." Click="OnCreateVector"/>
                <MenuItem Header="Create _Plane..." Click="OnCreatePlane"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Zoom to _Fit" Click="OnZoomToFit"/>
                <MenuItem Header="Toggle _Grid" Click="OnToggleGrid"/>
                <MenuItem Header="Toggle _Axes" Click="OnToggleAxes"/>
                <Separator/>
                <MenuItem Header="_Top View" Click="OnTopView"/>
                <MenuItem Header="_Front View" Click="OnFrontView"/>
                <MenuItem Header="_Right View" Click="OnRightView"/>
                <MenuItem Header="_Isometric View" Click="OnIsometricView"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About..." Click="OnAbout"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Entities: "/><Run Text="{Binding EntityCount, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content: Entity List | Viewport | Properties -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="220" MinWidth="120"/>
            </Grid.ColumnDefinitions>

            <!-- Entity List -->
            <DockPanel Grid.Column="0" Background="#FFF5F5F5">
                <TextBlock DockPanel.Dock="Top" Text="Entities" FontWeight="Bold" FontSize="13"
                           Margin="8,6" Foreground="#FF333333"/>
                <ListBox x:Name="EntityList"
                         ItemsSource="{Binding Entities}"
                         SelectionMode="Extended"
                         SelectionChanged="OnEntityListSelectionChanged"
                         BorderThickness="0" Background="Transparent"
                         Margin="4,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Rectangle Width="12" Height="12" Margin="0,0,6,0"
                                           Fill="{Binding Color, Converter={StaticResource ColorToBrush}}"
                                           Stroke="Gray" StrokeThickness="0.5"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#FFCCCCCC"/>

            <!-- 3D Viewport -->
            <views:ViewportView x:Name="ViewportControl" Grid.Column="2"/>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#FFCCCCCC"/>

            <!-- Properties Panel -->
            <views:PropertiesPanel x:Name="PropertiesPanelControl" Grid.Column="4"
                                   Background="#FFF5F5F5"/>
        </Grid>
    </DockPanel>
</Window>
