<UserControl x:Class="GeoModeler3D.App.Views.StatusBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StatusBar Height="24">
        <StatusBarItem>
            <TextBlock Text="{Binding StatusText}"/>
        </StatusBarItem>
        <Separator/>
        <StatusBarItem>
            <TextBlock>
                <Run Text="Entities: "/><Run Text="{Binding EntityCount, Mode=OneWay}"/>
            </TextBlock>
        </StatusBarItem>
        <Separator/>
        <StatusBarItem>
            <TextBlock>
                <Run Text="Selected: "/><Run Text="{Binding SelectedCount, Mode=OneWay}"/>
            </TextBlock>
        </StatusBarItem>
    </StatusBar>
</UserControl>
